# Synex - Environment Variables

# === Database (PostgreSQL) ===
# Para desarrollo local, instala PostgreSQL o usa Neon (neon.tech) gratis
DATABASE_URL=postgresql://user:password@localhost:5432/synex

# === Google OAuth ===
# Crea credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
# Para desarrollo local
CALLBACK_URL=http://localhost:5000/auth/google/callback
# Para producción (Vercel) - descomenta y ajusta:
# CALLBACK_URL=https://tu-app.vercel.app/auth/google/callback

# === Session ===
SESSION_SECRET=synex-super-secret-key-2024

# === URLs ===
PORT=5000
CLIENT_URL=http://localhost:5173
